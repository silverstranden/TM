function endDay() {
  var columns = [1,6,11,16,21,26,28],
      orderColumns = [2,3,4,5,7,8,9,10,12,13,14,15,17,18,19,20,22,23,24,25,27,29],
      shC = ss.getRange(defRange.current).getValue(),
      shS = ss.getRange(defRange.second).getValue(),
      shD = ss.getRange(defRange.delete).getValue(),
      shActive = SpreadsheetApp.getActive();
  
  var now = new Date(),
      year = now.getFullYear(),
      budYear = SpreadsheetApp.getActive().getSheetByName('Budget ' + year),
      date = Utilities.formatDate(new Date(), "GMT+1", "yyyy-MM-dd"),
      yesterday = (now - (1000 * 60 * 60 * 24)),
      total = ss.getRange(defRange.soldTdy).getValue();
  
  var budgetDate;
  var ssb = SpreadsheetApp.getActive().getSheetByName('Budget ' + year);
  var budget = ssb.getRange("'Budget "+ year +"'!B1:F");
  
  var budgetRow = ssb.getRange(defRange.budgetRow).getValue();
  
  ssb.getRange("E"+budgetRow).setValue(total); 
  
  if (ssb.getRange("E"+(budgetRow-1)).isBlank()){
        var ui = SpreadsheetApp.getUi();
        var response = ui.alert('Gäller denna försäljningen för dagen innan?', ui.ButtonSet.YES_NO);
        if (response == ui.Button.YES){
          ui.alert('Försäljningen satt för ' + yesterday)
          ssb.getRange("E"+(budgetRow-1)).setValue(total)
          SpreadsheetApp.getActive().getSheetByName(ss.getRange(defRange.current).getValue()).getRange(2, 15).setValue(yesterday)
          ssb.getRange("E"+budgetRow).clearContent();}
  }
  //Checks and creates sheets for correct quarter
  if (shActive.getSheetByName(shC) == null){
    makeSheet(shC,"#00ff00")
    if (shActive.getSheetByName(shS)!=null) {
      makeSheet(shS,"#ffff00")
    }
    if (shActive.getSheetByName(ss.getRange(defRange.delete).getValue()) != null) {
      shActive.deleteSheet(shD);
    }
  }
  
  var cs = shActive.getSheetByName(shC);
  cs.insertRowBefore(1);
  cs.getRange("A1:1").setBackground("#ffffff")
  cs.insertRowsBefore(1,107);
  copy(defRange.sheet,cs.getRange(1,1));
  
  
  // --- Start formatting for tomorrow ---
  for(var key in columns) {
    cs.setColumnWidth(columns[key],10);
  }
  for(var key in orderColumns) {
    cs.setColumnWidth(orderColumns[key],80);
  }
  
  //ready for tomorrow
  ss.hideRows(19,22)
  ss.hideRows(49,53)
  ss.hideColumns(22,5)
  cs.hideRows(19,22)
  cs.hideRows(49,53)
  cs.hideColumns(22,5)
  
  //clears content
  for(var key in range) {
    ss.getRange(range[key]).clearContent()}
  
  const formatCells = ["'Dagsförsäljning'!B6:E40","'Dagsförsäljning'!G6:J40","Dagsförsäljning!L6:O40","Dagsförsäljning!Q6:T40","Dagsförsäljning!V6:Y40","Dagsförsäljning!AA6:AA40",
                     "Dagsförsäljning!B42:E101","Dagsförsäljning!G42:J101","Dagsförsäljning!L42:O101","Dagsförsäljning!Q42:T101","Dagsförsäljning!V42:Y101","Dagsförsäljning!AA42:AA101"];
  formatBorder(formatCells)}

function copy(name, range) {
   SpreadsheetApp.getActiveSpreadsheet().getRange(name).copyTo(range, {formatsOnly:true});
   SpreadsheetApp.getActiveSpreadsheet().getRange(name).copyTo(range, {contentsOnly:true});}

function makeSheet(sheetName, color){
  var ss = SpreadsheetApp.getActive(),
      sheet = ss.getSheetByName(sheetName);
  
  if (sheet == null){
    sheet = ss.insertSheet()
    sheet.setName(sheetName)}
  sheet.setTabColor(color)}

function formatBorder(a1){
  if(Array.isArray(a1)){  a1.forEach(function myFunction(item) {
    ss.getRange(item).setFontColor("black").setFontFamily("lato").setFontSize(12).setBorder(true, true, true, true, true, true).setBackground("#fce5cd").setFontWeight("normal")
  })} else {a1.setFontColor("black").setFontFamily("lato").setFontSize(12).setBorder(true, true, true, true, true, true).setBackground("#fce5cd").setFontWeight("normal")}}
