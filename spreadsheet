function onEdit(event) {
    var ss = event.source.getSheetByName("Dagsförsäljning"),
        ssActive = SpreadsheetApp.getActive(),
        actRng = event.source.getActiveRange(),
        rIndex = actRng.getRowIndex(),
        cIndex = actRng.getColumnIndex(),
        cell = actRng.getCell(1,1),
        orderC = [2,7,12,17,22],
        cashC = [2,4,7,9,12,14,17,19,22,24],
        order;
    
    if (ss.getSheetId() == ssActive.getSheetId() && !(cell.isBlank())){
        if (rIndex > 17 && rIndex < 41 && cIndex < 27 || rIndex > 46 && rIndex < 101 && cIndex < 27){
          event.range.getSheet().showRows(rIndex+1,2);
        }
      if((cashC.indexOf(cIndex) || cashC.indexOf(cIndex)+1)&&rIndex<102&&rIndex>5&&rIndex!=41){formatBorder(cell)}
      if(orderC.indexOf(cIndex)+1 && (rIndex > 5 && rIndex < 41)){
        order = actRng.getValue().toUpperCase();
        cell.setValue('=HYPERLINK("http://dashboard.trademax.se/sales_orders/' + order + '";"' + order + '")');
      } else if (cashC.indexOf(cIndex)+1 && (rIndex > 41 && rIndex < 102)){
        order = actRng.getValue().toUpperCase();
        cell.setValue('=HYPERLINK("http://dashboard.trademax.se/sales_orders/' + order + '";"' + order + '")');
      }
    }
  }
  

